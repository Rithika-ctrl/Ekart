# ========================================================================
# EKART Backend API - Environment Configuration Template
# File: .env.example
# 
# ⚠️  IMPORTANT: This is a TEMPLATE ONLY. Copy to .env and fill with real values.
#     NEVER commit .env to Git — it contains sensitive credentials.
#     .env is already in .gitignore and will NOT be tracked.
# ========================================================================

# API Server Configuration
PORT=3001
NODE_ENV=development

# TiDB Cloud Database Configuration
DB_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your-tidb-user
DB_PASSWORD=your-tidb-password
DB_NAME=ekart
DB_POOL_LIMIT=10

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# React Frontend Configuration - Updated to use Spring Boot backend on port 8080
REACT_APP_API_URL=http://localhost:8080/api/flutter
VITE_API_BASE=/api/react

# ========================================================================
# 🔐 AES ENCRYPTION KEYS - FOR PASSWORD ENCRYPTION
# ========================================================================
# ⚠️  CRITICAL SECURITY: These keys encrypt all vendor/customer passwords
#     Never expose these values. Use strong randomized values in production.
#
#     TO GENERATE STRONG KEYS (on Linux/macOS):
#       AES_SECRET (32 chars): openssl rand -base64 32
#       AES_SALT (16 chars):   openssl rand -base64 16
#
#     TO GENERATE STRONG KEYS (on Windows PowerShell):
#       [System.Convert]::ToBase64String((New-Object System.Security.Cryptography.RNGCryptoServiceProvider).GetBytes(32))
#       [System.Convert]::ToBase64String((New-Object System.Security.Cryptography.RNGCryptoServiceProvider).GetBytes(16))
#
#     NEVER commit real keys to Git. .env is in .gitignore.
#     
#     ROTATING KEYS (advanced):
#     If you need to rotate keys in production:
#     1. Generate new AES_SECRET and AES_SALT
#     2. Create a database migration to re-encrypt all passwords with new keys
#     3. Update these values in .env
#     4. Deploy and run migration
#     5. Old encrypted passwords will NOT be readable with new keys
#
AES_SECRET=change-me-to-strong-32-char-secret-key-in-production
AES_SALT=change-me-to-strong-16-char-salt

# ========================================================================
# 🔐 ADMIN AUTHENTICATION - TWO-FACTOR AUTHENTICATION (2FA)
# ========================================================================
# Admin credentials are now stored in the database (admin_credential table)
# instead of hardcoded in properties. This ensures credentials are never
# exposed in version control or configuration files.
#
# INITIAL ADMIN SETUP:
# 1. Create the admin_credential table using Flyway migration V002
#    File: EKART/src/main/resources/db/migration/V002__Create_AdminCredential_Table.sql
#
# 2. Insert initial admin into database using SQL:
#    (Choose ONE method based on your password generation preference)
#
#    METHOD A: Using bcrypt.online (https://bcrypt.online)
#    ========================================================
#    Password: your-super-secret-admin-password
#    Hash:     (use bcrypt.online to generate BCrypt hash)
#    Then run:
#    INSERT INTO admin_credential 
#      (email, hashed_password, name, two_factor_enabled, failed_attempts, locked, created_at)
#    VALUES 
#      ('admin@ekart.com', '$2a$10$...bcrypt-hash...', 'Admin', false, 0, false, NOW());
#
#    METHOD B: Using Spring Boot Java (in terminal)
#    ================================================
#    java -jar target/ekart-0.0.1-SNAPSHOT.jar --generate-admin-bcrypt='your-password'
#
#    METHOD C: Using Linux/macOS OpenSSL + Spring Boot
#    ==================================================
#    $ htpasswd -B -C 10 -c admin.txt admin@ekart.com
#    (Enter password when prompted, bcrypt hash will be in admin.txt)
#    Then copy hash to SQL INSERT statement below
#
# 3. Verify admin account:
#    SELECT email, name, two_factor_enabled FROM admin_credential WHERE email='admin@ekart.com';
#
# ADMIN TWO-FACTOR AUTHENTICATION (2FA):
# ========================================
# - 2FA is OPTIONAL by default (two_factor_enabled = false initially)
# - To enable 2FA: Use the /api/admin/enable-2fa endpoint
# - To disable 2FA: Use the /api/admin/disable-2fa endpoint
# - 2FA uses Time-based One-Time Password (TOTP) - compatible with:
#   * Google Authenticator
#   * Microsoft Authenticator
#   * Authy
#   * Any RFC 6238 compliant app
#
# ADMIN ACCOUNT SECURITY:
# =======================
# - Failed login limit: 5 attempts
# - Auto-lockout duration: 15 minutes
# - Account automatically unlocks after lockout period
# - Password hashing: BCrypt (NIST SP 800-132 compliant)
# - All admin credentials MUST be stored in database only
# - NO admin credentials in environment variables or .properties files
#
# DEFAULT LOGIN FLOW (without 2FA):
# ==================================
# POST /api/react/auth/admin/login
# {
#   "email": "admin@ekart.com",
#   "password": "your-super-secret-admin-password"
# }
# Response:
# {
#   "success": true,
#   "adminId": 1,
#   "requires2FA": false,
#   "token": "jwt-token-here"
# }
#
# LOGIN FLOW WITH 2FA (if enabled):
# ==================================
# Step 1: Send email and password
# POST /api/react/auth/admin/login
# {
#   "email": "admin@ekart.com",
#   "password": "supa-secret"
# }
# Response (requires 2FA):
# {
#   "success": true,
#   "adminId": 1,
#   "requires2FA": true,
#   "message": "Please provide 2FA code"
# }
#
# Step 2: Send 2FA code (6-digit code from authenticator app)
# POST /api/react/auth/admin/verify-2fa
# {
#   "adminId": 1,
#   "totpCode": "123456"
# }
# Response:
# {
#   "success": true,
#   "token": "jwt-token-here"
# }
