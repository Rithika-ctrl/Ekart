# ========================================================================
# EKART Backend API - Environment Configuration (TEMPLATE)
# File: .env.example
# ========================================================================
# SECURITY: This is a TEMPLATE. Never commit real .env files to Git!
#
# Setup:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials in .env
# 3. Add .env to .gitignore (already done)
# 4. NEVER commit .env to version control
# ========================================================================

# API Server Configuration
PORT=3001
NODE_ENV=development

# TiDB Cloud Database Configuration
# Get credentials from: https://tidbcloud.com/console/clusters
DB_HOST=your-tidbcloud-host.ap-southeast-1.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your-user@root
DB_PASSWORD=your-password-here
DB_NAME=ekart
DB_POOL_LIMIT=10

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Frontend API Configuration (Vite)
VITE_API_BASE=http://localhost:8080/api/flutter

# ========================================================================
# 🔐 AES ENCRYPTION KEYS - FOR PASSWORD ENCRYPTION (DEPRECATED APPROACH)
# ========================================================================
# ⚠️  CRITICAL SECURITY WARNING:
#     The application currently encrypts passwords using AES (reversible).
#     This is NOT recommended for production. Use bcrypt (one-way hashing) instead.
#
# Timeline to fix:
# 1. IMMEDIATE (Now): Use STRONG 256-bit random keys (not weak defaults)
# 2. SHORT-TERM: Add bcrypt alongside AES for new registrations
# 3. LONG-TERM: Migrate all existing passwords to bcrypt
#
# FOR CURRENT DEPLOYMENT - Generate 256-bit random keys:
#   AES_SECRET: openssl rand -base64 32    (produces 44-char base64 string)
#   AES_SALT:   openssl rand -base64 32    (produces 44-char base64 string)
#
# NEVER use simple strings like "123456789" or "abcdefg" —那 are trivial to brute-force
#
AES_SECRET=YOUR-STRONG-32-BYTE-BASE64-ENCODED-SECRET-FROM-OPENSSL
AES_SALT=YOUR-STRONG-32-BYTE-BASE64-ENCODED-SALT-FROM-OPENSSL

# ========================================================================
# 📧 EMAIL CONFIGURATION (Gmail SMTP)
# ========================================================================
# Generate app password: https://myaccount.google.com/apppasswords
# Do NOT use your main Gmail password
#
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_FROM=noreply@ekart.com

# ========================================================================
# 📷 CLOUDINARY CONFIGURATION (Image Storage)
# ========================================================================
# Get credentials from: https://cloudinary.com/console
#
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ========================================================================
# 🤖 GOOGLE GEMINI API (AI Assistant)
# ========================================================================
# Get API key from: https://aistudio.google.com/app/apikey
#
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here

# ========================================================================
# 👨‍💼 ADMIN AUTH (DB + BCRYPT)
# ========================================================================
# Admin authentication is database-backed (admin_credential table).
# Do NOT configure admin password in environment files.
# Keep only non-secret metadata here if needed.
#
ADMIN_EMAIL=admin@ekart.com

# ========================================================================
# 🛡️ JWT Configuration
# ========================================================================
# Generate JWT secret: openssl rand -base64 64
#
JWT_SECRET=your-generated-jwt-secret-here
JWT_EXPIRATION=86400

# ========================================================================
# � RAZORPAY PAYMENT GATEWAY
# ========================================================================
# Get credentials from: https://dashboard.razorpay.com/app/settings
#
# SECURITY: These keys are required for payment processing
# - RAZORPAY_KEY_ID: Public key (can be exposed to frontend)
# - RAZORPAY_KEY_SECRET: Secret key (MUST be kept secret, backend only)
#
# DO NOT expose RAZORPAY_KEY_SECRET in frontend code
#
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret-key-here

# ========================================================================
# 📊 ANALYTICS (Optional)
# ========================================================================
# ANALYTICS_API_KEY=your-analytics-key-here

