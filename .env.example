# ===============================
# ENVIRONMENT VARIABLES CONFIGURATION
# ===============================
# Copy this file to .env and fill in your actual credentials
# NEVER commit the .env file to version control!
# This file documents ALL required environment variables

# ===============================
# EMAIL CONFIG (Gmail SMTP)
# ===============================
# Using Gmail: Generate app-specific password at https://myaccount.google.com/apppasswords
# DO NOT use your actual Gmail password - it won't work!
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password

# ===============================
# CLOUDINARY MEDIA STORAGE
# ===============================
# Create free account at: https://cloudinary.com
# Used for: Product images, videos, banners
CLOUDINARY_CLOUD=your-cloud-name
CLOUDINARY_KEY=your-api-key
CLOUDINARY_SECRET=your-api-secret

# ===============================
# ADMIN DEFAULT LOGIN
# ===============================
# IMPORTANT: Change these values immediately after first login!
# Password must be: 8+ chars, 1 uppercase, 1 lowercase, 1 number, 1 special character
ADMIN_EMAIL=admin@ekart.com
ADMIN_PASSWORD=Admin@123!

# ===============================
# ENCRYPTION CONFIG (AES)
# ===============================
# Used for encrypting customer passwords and sensitive data
# Generate random values for production!
# Example online: https://www.random.org
AES_SECRET=generate-a-32-character-random-string-here-xxxx
AES_SALT=generate-a-16-character-salt-here

# ===============================
# GOOGLE OAUTH2 CONFIG
# ===============================
# Setup: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
# Available for: Customer, Vendor, Admin
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ===============================
# FACEBOOK OAUTH2 CONFIG
# ===============================
# Setup: https://developers.facebook.com/apps/
# Valid OAuth Redirect URI: http://localhost:8080/login/oauth2/code/facebook
# Available for: Customer, Vendor, Admin
FACEBOOK_CLIENT_ID=your-facebook-app-id-here
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret-here

# ===============================
# INSTAGRAM OAUTH2 CONFIG
# ===============================
# Setup: https://developers.facebook.com/docs/instagram-basic-display-api
# Uses Facebook's OAuth infrastructure
# Valid OAuth Redirect URI: http://localhost:8080/login/oauth2/code/instagram
# Available for: Customer, Vendor, Admin
INSTAGRAM_CLIENT_ID=your-instagram-app-id-here
INSTAGRAM_CLIENT_SECRET=your-instagram-app-secret-here

# ===============================
# GITHUB OAUTH2 CONFIG
# ===============================
# Setup: https://github.com/settings/developers
# Authorization callback URL: http://localhost:8080/login/oauth2/code/github
# Available for: Admin ONLY
GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here

# ===============================
# GOOGLE GEMINI API CONFIG
# ===============================
# Create API key at: https://ai.google.dev
# Used for: AI Assistant feature
GEMINI_API_KEY=your-gemini-api-key-here

# ===============================
# APPLICATION CONFIG
# ===============================
SERVER_PORT=8080
SPRING_APPLICATION_NAME=ekart

# Database (H2 file-based for development)
SPRING_DATASOURCE_URL=jdbc:h2:file:./ekart_db
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# Show SQL queries in logs (disable in production)
JPA_SHOW_SQL=false
