# ===============================
# OAUTH2 SOCIAL LOGIN CREDENTIALS
# ===============================
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control!

# Google OAuth2 (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
# Available for: Customer, Vendor, Admin
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Facebook OAuth2 (https://developers.facebook.com/apps/)
# Valid OAuth Redirect URI: http://localhost:8080/login/oauth2/code/facebook
# Available for: Customer, Vendor, Admin
FACEBOOK_CLIENT_ID=your-facebook-app-id-here
FACEBOOK_CLIENT_SECRET=your-facebook-app-secret-here

# Instagram OAuth2 (https://developers.facebook.com/docs/instagram-basic-display-api)
# Valid OAuth Redirect URI: http://localhost:8080/login/oauth2/code/instagram
# Available for: Customer, Vendor, Admin
INSTAGRAM_CLIENT_ID=your-instagram-app-id-here
INSTAGRAM_CLIENT_SECRET=your-instagram-app-secret-here

# GitHub OAuth2 (https://github.com/settings/developers)
# Authorization callback URL: http://localhost:8080/login/oauth2/code/github
# Available for: Admin ONLY
GITHUB_CLIENT_ID=your-github-client-id-here
GITHUB_CLIENT_SECRET=your-github-client-secret-here
